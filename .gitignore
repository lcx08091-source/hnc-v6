# Compiled binaries that CI builds from source - exclude from git
bin/hnc_dpid
bin/hnc_watchdog
bin/hnc_dpid_supervisor
bin/hnc_tc_ingress
bin/hnc_launcher
bin/fork_probe
daemon/hnc_httpd/hnc_httpd
# v5.8.3 (audit): libbpf is now a git submodule (third_party/libbpf @ v1.4.7),
# so CI builds these from source every run instead of shipping stale committed
# blobs (this is how the rc39/rc43 C fixes had silently failed to ship).
bin/hotspotd
bin/hnc_ipc
bin/mdns_resolve

# Pre-built binaries that DO go in git (no source in this repo, can't be CI-built):
# - bin/hnc_ndpi_probe  (committed)

# Build artifacts
**/_libs_out/
**/_obj/
**/build/
**/out/
**/prebuilt/
*.o
*.a

# v5.8.5 (audit): exceptions to the *.a rule above — these prebuilt Android
# arm64 static libs (JiaHuann/libbpf-bootstrap-android, BSD-3) are REQUIRED by
# the hotspotd CI build (build_libs.sh copies them); they must ship in git.
# Previously the blanket *.a rule kept them out of the repo, so CI's fresh
# checkout had no libelf.a/libz.a and the hotspotd build failed.
!third_party_prebuilt/libelf/libelf.a
!third_party_prebuilt/libz/libz.a

# Backup and temp
*.bak
*.tmp
*.old
*.orig
*.rej
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

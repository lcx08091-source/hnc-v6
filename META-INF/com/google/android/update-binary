SKIPUNZIP=1

ui_print ""
ui_print "  +======================================+"
ui_print "  |    HNC - Hotspot Network Control     |"
ui_print "  |    Version 3.1.0                     |"
ui_print "  |    Author: Claude (Anthropic AI)     |"
ui_print "  +======================================+"
ui_print ""

ui_print "  [1/4] 解压模块文件..."
unzip -o "$ZIPFILE" -x 'META-INF/*' -d "$MODPATH" >&2

ui_print "  [2/4] 设置文件权限..."
set_perm_recursive "$MODPATH/bin"  root root 0755 0755
set_perm_recursive "$MODPATH/api"  root root 0755 0755
set_perm "$MODPATH/service.sh"       root root 0755
set_perm "$MODPATH/post-fs-data.sh"  root root 0755

ui_print "  [3/4] 初始化数据目录..."
mkdir -p /data/local/hnc/{bin,api,data,logs,run}
cp -f "$MODPATH/bin/"*.sh      /data/local/hnc/bin/ && chmod 755 /data/local/hnc/bin/*.sh
cp -f "$MODPATH/api/server.sh" /data/local/hnc/api/ && chmod 755 /data/local/hnc/api/server.sh
[ ! -f /data/local/hnc/data/rules.json ] && cp "$MODPATH/data/rules.json" /data/local/hnc/data/

ui_print "  [4/4] 完成！"
ui_print ""
ui_print "  +======================================+"
ui_print "  |          ** 安 装 成 功 **           |"

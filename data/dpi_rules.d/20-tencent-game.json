        "rate_thresholds": {
          "foreground_active_playing": ">10 queries/min (实际数据: 前台连续游戏可达 12+/min)",
          "background_keepalive": "1-5 queries/min (游戏在后台不杀进程)",
          "killed": "0 queries/min (5+ 分钟无查询 = 已退出)"
        }
      },
      "note": "查询频率是腾讯游戏前台/后台/已杀的金标准判别. HNC 可用作 'app foreground state' 信号, 不只是'app 是否安装'",
      "ground_truth": {
        "verified": true,
        "date": "2026-05-18",
        "evidence": [
          "K80 火影后台保活: 20 queries / 5min = 4/min (背景节奏)",
          "RMX5010 PUBG 前台: 26+ queries / 5min ~= 5+/min (但屏幕亮+操作)"
        ]
      }
